# Serv# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/cococodeEnvironment Variables

# Server
PORT=3001
NODE_ENV=production

# Database (use service name "postgres" when running in Docker Compose)
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/cococode
REDIS_URL=redis://redis:6379

# Authentication
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# AI (Gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_AUTOCOMPLETE_KEY=your-gemini-autocomplete-key

# OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS — set to your domain in production
CORS_ORIGIN=http://localhost
