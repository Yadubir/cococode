# Server
PORT=3001
NODE_ENV=production

# Database
# Local: postgresql://user:pass@localhost:5432/db
# Render: postgresql://user:pass@host.render.com/db
# Neon: postgresql://user:pass@region.neon.tech/db
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/cococode

# Authentication
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# AI (Gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_AUTOCOMPLETE_KEY=your-gemini-autocomplete-key

# OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS — set to your domain in production
CORS_ORIGIN=http://localhost
