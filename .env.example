# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cococode

# ── Frontend build-time env (baked into Vite bundle) ─────────────────────────
